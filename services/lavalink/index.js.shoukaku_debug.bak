const { Shoukaku, Connectors } = require("shoukaku");

let instance;

module.exports = function createShoukaku(client) {
  console.log("🔥 CREATE SHOUKAKU CALLED");
  if (global.__SHOUKAKU__) return global.__SHOUKAKU__;

  const nodes = [
    {
      name: "lavalink",
      url: `${process.env.LAVALINK_HOST}:${process.env.LAVALINK_PORT}`,
      auth: process.env.LAVALINK_PASSWORD,
      secure: process.env.LAVALINK_SECURE === "true"
    }
  ];

  console.log("HOST:", process.env.LAVALINK_HOST);
  console.log("PORT:", process.env.LAVALINK_PORT);
  console.log("SECURE:", process.env.LAVALINK_SECURE);
  console.log(
    "PASSWORD:",
    process.env.LAVALINK_PASSWORD ? "SET" : "MISSING"
  );
  console.log(
    "NODE URL:",
    `${process.env.LAVALINK_HOST}:${process.env.LAVALINK_PORT}`
  );

  instance = new Shoukaku(
    new Connectors.DiscordJS(client),
    nodes,
    {
      moveOnDisconnect: true,
      resume: true,
      resumeTimeout: 60,
      reconnectTries: Infinity,
      reconnectInterval: 5000
    }
  );

  global.__SHOUKAKU__ = instance;

  instance.on("ready", (name) => {
    console.log("🟢 SHOUKAKU CONNECTED:", name);
  });

  instance.on("error", (_name, err) => {
    console.error("🔴 SHOUKAKU ERROR:", err?.message || err);
  });

  instance.on("disconnect", () => {
    console.warn("🟠 SHOUKAKU DISCONNECTED");
  });

  return instance;
};
