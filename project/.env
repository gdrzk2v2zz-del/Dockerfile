# =========================
# DISCORD
# =========================
TOKEN=__PUT_SECURE_SECRET_HERE__
CLIENT_ID=1505072294148440104

# =========================
# LAVALINK CLUSTER
# =========================
LAVALINK_NODES=primary,backup
LAVALINK_MODE=failover

LAVALINK_PRIMARY_HOST=lavalink-primary.internal
LAVALINK_PRIMARY_PORT=2333
LAVALINK_PRIMARY_PASSWORD=__RANDOM_PRIMARY_SECRET__

LAVALINK_BACKUP_HOST=lavalink-backup.internal
LAVALINK_BACKUP_PORT=2333
LAVALINK_BACKUP_PASSWORD=__RANDOM_BACKUP_SECRET__

# =========================
# FAILOVER CONTROL
# =========================
LAVALINK_HEALTHCHECK_INTERVAL=5000
LAVALINK_FAILOVER_TIMEOUT=3000
LAVALINK_FALLBACK_ENABLED=true

# =========================
# ENVIRONMENT
# =========================
NODE_ENV=production
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_METRICS=true
