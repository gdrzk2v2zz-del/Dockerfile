# =====================================================
# DISCORD BOT
# =====================================================
TOKEN=YOUR_DISCORD_BOT_TOKEN
CLIENT_ID=YOUR_CLIENT_ID

# =====================================================
# ENVIRONMENT
# =====================================================
NODE_ENV=production
LOG_LEVEL=info
LOG_FORMAT=json

# =====================================================
# DISCORD SHARDING
# =====================================================
SHARDING_ENABLED=true
SHARD_COUNT=auto
SHARD_MANAGER_URL=http://shard-manager:3000

# =====================================================
# LAVALINK CLUSTER
# =====================================================
# comma-separated logical nodes
LAVALINK_NODES=primary,backup

# mode: failover | round-robin | weighted
LAVALINK_MODE=failover

# primary / backup endpoints (explicit failover routing)
LAVALINK_PRIMARY_URL=http://lavalink-primary:2333
LAVALINK_BACKUP_URL=http://lavalink-backup:2333

# authentication (per-node recommended)
LAVALINK_PRIMARY_PASSWORD=CHANGE_ME_PRIMARY
LAVALINK_BACKUP_PASSWORD=CHANGE_ME_BACKUP

# =====================================================
# FAILOVER / RESILIENCE
# =====================================================
LAVALINK_HEALTH_ENDPOINT=/v4/info
LAVALINK_HEALTHCHECK_INTERVAL=5000
LAVALINK_FAILOVER_TIMEOUT=3000
LAVALINK_RETRY_COUNT=3
LAVALINK_RETRY_BACKOFF=500
LAVALINK_FALLBACK_ENABLED=true

# =====================================================
# EVENT BUS (Redis Streams)
# =====================================================
EVENT_BUS_URL=redis://redis:6379
EVENT_BUS_STREAM=rf-events

# =====================================================
# DATABASE
# =====================================================
POSTGRES_URL=postgres://rf:rfpass@postgres:5432/rfstudio
POSTGRES_POOL_SIZE=10

# =====================================================
# OBSERVABILITY
# =====================================================
ENABLE_METRICS=true
METRICS_PORT=9100

ENABLE_TRACING=false
OTEL_EXPORTER_ENDPOINT=http://tempo:4318

# =====================================================
# SECURITY
# =====================================================
RATE_LIMIT_ENABLED=true
ABUSE_DETECTION=true
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
